// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Note {
  id         String   @id @default(uuid())
  title      String   @default("Catatan Baru")
  content    String   @default("")
  summary    String   @default("")
  tags       String[] @default([])
  todo_list  Json     @default("[]")
  created_at DateTime @default(now())
  folder_id  String?
  folder     Folder?  @relation(fields: [folder_id], references: [id], onDelete: SetNull)

  @@map("notes")
}

model Folder {
  id         String   @id @default(uuid())
  name       String
  created_at DateTime @default(now())
  parentId   String?  @map("parent_id")
  parent     Folder?  @relation("Subfolders", fields: [parentId], references: [id], onDelete: Cascade)
  subfolders Folder[] @relation("Subfolders")
  notes      Note[]

  @@map("folders")
}

model ScheduledJob {
  id         String   @id @default(uuid())
  command    String
  actionType String   // "whatsapp", "news_summary", "create_note"
  payload    Json
  runAt      DateTime
  status     String   @default("pending") // pending, completed, failed
  created_at DateTime @default(now())

  @@map("scheduled_jobs")
}

model Reminder {
  id             String   @id @default(uuid())
  title          String
  description    String?
  dateTime       DateTime
  notify1Day     Boolean  @default(true)
  notify1Hour    Boolean  @default(true)
  notifyExact    Boolean  @default(true)
  sent1Day       Boolean  @default(false)
  sent1Hour      Boolean  @default(false)
  sentExact      Boolean  @default(false)
  created_at     DateTime @default(now())
  whatsappNumber String?

  @@map("reminders")
}

model PushSubscription {
  id        String   @id @default(uuid())
  endpoint  String   @unique
  keys      Json     // format: { auth: string, p256dh: string }
  createdAt DateTime @default(now())

  @@map("push_subscriptions")
}

